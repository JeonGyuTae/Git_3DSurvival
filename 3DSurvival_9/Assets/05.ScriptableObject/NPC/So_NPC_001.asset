  m_Script: {fileID: 11500000, guid: 6b712a4ac05d2e7438ac993aeb5bfbaa, type: 3}
  m_Name: So_NPC_001
  m_EditorClassIdentifier: 
  npcName: Panel001
  displayName: "\uD33B\uB9D0"
  dialogues:
  - "[ \uAC8C\uC784 \uCEE8\uC149 \uD33B\uB9D0 ]\r\n\uC774 \uD33B\uB9D0\uC740\r\n\uAC8C\uC784\uC758
    \uCEE8\uC149\uACFC \uBAA9\uC801\uC5D0 \uB300\uD574 \uC548\uB0B4\uD569\uB2C8\uB2E4.\r\n(Space
    \uD0A4\uB97C \uC785\uB825\uD558\uC5EC \uB2E4\uC74C\uC73C\uB85C \uB118\uC5B4\uAC11\uB2C8\uB2E4.)"
  - "\uC774 \uACF3\uC740 \uBB34\uC778\uB3C4 \uC785\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740
    \uBD88\uC758\uC758 \uC0AC\uACE0\uB85C \uC778\uD574\r\n\uC774 \uC12C\uC73C\uB85C
    \uB5A0\uBC00\uB824 \uC654\uC2B5\uB2C8\uB2E4."
  - "\uB2F9\uC2E0\uC758 \uBAA9\uC801\uC740\r\n\uB5CF\uBAA9\uC744 \uB9CC\uB4E4\uC5B4
    \uC774 \uC12C\uC5D0\uC11C \uD0C8\uCD9C\uD558\uB294 \uAC83\uC785\uB2C8\uB2E4.\r\n\uB5CF\uBAA9\uC744
    \uB9CC\uB4E4\uAE30 \uC704\uD574\uC11C\uB294 \uC7AC\uB8CC\uAC00 \uD544\uC694\uD569\uB2C8\uB2E4."
  - "\uB610\uD55C \uC774 \uC12C\uC5D0\uB294 \uC5EC\uB7EC \uB3D9\uBB3C\uB4E4\uC774
    \uC11C\uC2DD\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4.\r\n\uB2ED, \uC0AC\uC2B4\uC740
    \uC628\uC21C\uD558\uC5EC \uACF5\uACA9\uD558\uC9C0 \uC54A\uC9C0\uB9CC\r\n\uD638\uB791\uC774\uB294
    \uACF5\uACA9\uC131\uC774 \uAC15\uD558\uC5EC \uBA3C\uC800 \uB2EC\uB824\uB4E4 \uC218
    \uC788\uAE30\uC5D0\r\n\uD56D\uC0C1 \uACBD\uACC4\uB97C \uB2A6\uCDB0\uC120 \uC548\uB429\uB2C8\uB2E4."
  - "\uC704\uC640 \uAC19\uC740 \uD53C\uC2B5\uC744 \uBC29\uC9C0\uD558\uAE30 \uC704\uD574\r\n\uC9D1\uC744
    \uC9C0\uC5B4 \uC548\uC804\uAD6C\uC5ED\uC744 \uC0DD\uC131\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\r\n\uB3D9\uBB3C\uB4E4\uC740
    \uC548\uC804\uAD6C\uC5ED \uB0B4\uB85C \uC9C4\uC785\uD560 \uC218 \uC5C6\uC73C\uBA70,\r\n\uB5CF\uBAA9\uACFC
    \uB9C8\uCC2C\uAC00\uC9C0\uB85C \uC81C\uC791 \uC7AC\uB8CC\uAC00 \uD544\uC694\uD569\uB2C8\uB2E4."
