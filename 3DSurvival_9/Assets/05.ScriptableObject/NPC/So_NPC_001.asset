  m_Script: {fileID: 11500000, guid: 6b712a4ac05d2e7438ac993aeb5bfbaa, type: 3}
  m_Name: So_NPC_001
  m_EditorClassIdentifier: 
  npcName: Panel
  displayName: "\uD33B\uB9D0"
  dialogues:
  - "[\uC8FC\uC758!]\n\uC774 \uACF3\uC740 \uBB34\uC778\uB3C4 \uC785\uB2C8\uB2E4.\n\uC774
    \uD33B\uB9D0\uC740 \uAC8C\uC784\uC758 \uAE30\uBCF8 \uC124\uBA85\uC5D0 \uB300\uD574
    \uC548\uB0B4\uD569\uB2C8\uB2E4."
  - "Player UI\uC5D0 \uD45C\uC2DC\uB418\uB294 Stat\uC740 \uD06C\uAC8C 4\uAC00\uC9C0\uB85C\n\uCCB4\uB825,
    \uAD76\uC8FC\uB9BC, \uAC08\uC99D, \uD589\uB3D9\uB825 \uC774 \uC788\uC2B5\uB2C8\uB2E4.\n(\uD574\uB2F9
    \uC124\uBA85\uC740 \uC218\uC815\uC774 \uD544\uC694\uD569\uB2C8\uB2E4.)"
  - "\uD0A4\uBCF4\uB4DC \uC785\uB825\uC744 \uD1B5\uD574 Player\uB97C \uC870\uC791\uD560
    \uC218 \uC788\uC2B5\uB2C8\uB2E4.\nW, A, S, D \uB85C \uC774\uB3D9\uD560 \uC218
    \uC788\uC73C\uBA70\nSpace \uB85C \uC810\uD504\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uD0A4\uBCF4\uB4DC \uC785\uB825\uC744 \uD1B5\uD574 \uCD94\uAC00 \uD589\uB3D9\uC744
    \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\nCtrl + \uC774\uB3D9\uD0A4 \uB85C Stamina\uB97C
    \uC18C\uBAA8\uD558\uC5EC \uB2EC\uB9B4 \uC218 \uC788\uC73C\uBA70,\nShift \uB85C
    \uC549\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uB9C8\uC6B0\uC2A4 \uC785\uB825\uC744 \uD1B5\uD574 \uC0C1\uD638\uC791\uC6A9\uC744
    \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\uC88C\uD074\uB9AD \uC2DC \uC804\uBC29\uC744
    \uD5A5\uD574 \uACF5\uACA9/\uCC44\uC9D1\uD558\uBA70,\n\uC6B0\uD074\uB9AD \uC2DC
    \u3147 \uD569\uB2C8\uB2E4.\n(\uD574\uB2F9 \uC124\uBA85\uC740 \uC218\uC815\uC774
    \uD544\uC694\uD569\uB2C8\uB2E4.)"
